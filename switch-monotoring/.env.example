# Copy this file to .env and fill in real values. NEVER commit .env to git.

# ── Oracle Database ──────────────────────────────────────────────────────────
DB_URL=jdbc:oracle:thin:@//localhost:1521/XEPDB1
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── SMTP ─────────────────────────────────────────────────────────────────────
# Gmail : générer un App Password sur myaccount.google.com → Sécurité → Mots de passe des applications
# Office 365 : MAIL_HOST=smtp.office365.com  MAIL_PORT=587
# Mailtrap (dev) : MAIL_HOST=sandbox.smtp.mailtrap.io  MAIL_PORT=2525
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
MAIL_FROM=your_email@gmail.com
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true
MAIL_STARTTLS_REQUIRED=true

# ── Frontend ─────────────────────────────────────────────────────────────────
# URL du frontend autorisée par le backend (sans slash final)
FRONTEND_URL=http://localhost:4200
